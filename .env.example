# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/mingle_db?schema=public"

# NextAuth Configuration
# Secret key for NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-replace-with-generated-value"

# Application URL - Use http://localhost:3000 for local development
NEXTAUTH_URL="http://localhost:3000"

# Production URL (uncomment and set when deploying)
# NEXTAUTH_URL="https://your-production-domain.com"

# Optional: Additional Configuration

# Node Environment (development, production, test)
NODE_ENV="development"

# Optional: Email Configuration (if using email features)
# EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
# EMAIL_FROM="noreply@example.com"

# Optional: OAuth Providers (if using social login)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# Optional: File Upload Configuration
# MAX_FILE_SIZE="5242880" # 5MB in bytes
# UPLOAD_DIR="./public/uploads"

# Optional: Redis Configuration (if using caching)
# REDIS_URL="redis://localhost:6379"

# Optional: Application Settings
# APP_NAME="Mingle"
# APP_URL="http://localhost:3000"

# Optional: Analytics (if configured)
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Optional: Sentry (error tracking)
# SENTRY_DSN="your-sentry-dsn"

# Optional: Feature Flags
# ENABLE_CHAT="true"
# ENABLE_VIDEO_CALL="false"
